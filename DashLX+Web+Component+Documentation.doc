<tr data-local-id=3D"be92fecb-5bc0-4622-9f94-74d7148be8aa">
<td colspan=3D"3" data-local-id=3D"653bde59-dd9f-47a5-b78d-419d8f3022f7" cl=
ass=3D"confluenceTd">
<p local-id=3D"93f4b22f-a271-4036-8fbe-9ee7c92a0941"><strong>Headers</stron=
g></p></td>
</tr>
<tr data-local-id=3D"56ae68a4-59bd-42d3-b2f6-9e1161a7106d">
<td data-local-id=3D"7e1bb706-b792-4674-a2ff-5f052a32f2a8" class=3D"conflue=
nceTd">
<p local-id=3D"8d9b7d04-dcba-425a-902e-8c2d8f208804">Authorization</p></td>
<td colspan=3D"2" data-local-id=3D"d2871688-6d7e-46b3-ba47-5a8da448f13a" cl=
ass=3D"confluenceTd">
<p local-id=3D"7ade22d3-0163-4168-9a53-98297b360031">string, A base64 encod=
ed string of this format =E2=80=9CclientId:secret=E2=80=9D. Same authentica=
tion mechanism as the begin-session endpoint.</p>
<hr local-id=3D"3109ed24-4d05-4579-8497-16f67b9f279a">
<p local-id=3D"8978ffc7-037a-405d-8873-f316e3d1e59a">Uses Basic authenticat=
ion. Example:</p>
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
<div class=3D"codeContent panelContent pdl">
<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: java; gutter: false; theme: Confluence" data-theme=3D"Confluence">Basic &=
lt;base64EncodeStr(clientId:secret)&gt;</pre>
</div>
</div></td>
</tr>
<tr data-local-id=3D"ebe59e59-79e7-4bfc-96fe-998a57c62d37">
<td colspan=3D"2" data-local-id=3D"2900b73c-8e70-4954-a7e5-d9f15cff0f72" cl=
ass=3D"confluenceTd">
<p local-id=3D"85b35ce2-9776-4c57-836c-41f8e3f53879"><strong>Body Parameter=
s</strong></p></td>
<td data-local-id=3D"18e8f8eb-ff72-47a8-a57e-ba007b03d15e" class=3D"conflue=
nceTd">
<p local-id=3D"cd5d4646-2214-4f96-94ce-81807114b232"></p></td>
</tr>
<tr data-local-id=3D"338829bc-3e04-40f3-84d8-4f1d53754de7">
<td data-local-id=3D"b237150c-8b8d-44ad-b28f-8d8b051ac9f3" class=3D"conflue=
nceTd">
<p local-id=3D"fdc42b9d-c78d-4e7a-b4f2-ac8b2e0a9204">email</p></td>
<td data-local-id=3D"6c074113-a886-405e-8301-3df5d6b5031f" class=3D"conflue=
nceTd">
<p local-id=3D"4684c8aa-4b84-49a8-9bcb-7445f03b30dc">string</p></td>
<td data-local-id=3D"cd3db603-4f23-472e-94bc-067db459d59b" class=3D"conflue=
nceTd">
<p local-id=3D"b6dfa8b0-2f5b-4343-89da-3cbdd1eb1b92">Email of user to check=
 status of.</p></td>
</tr>
<tr data-local-id=3D"d5ecc723-12c6-40e6-9c40-ea5bff8e9eb1">
<td data-local-id=3D"3115d2b3-7701-4f92-b55e-6a03aa859c21" class=3D"conflue=
nceTd">
<p local-id=3D"dc21251d-0041-475d-8c35-4e2d23dd05b7">cohort</p></td>
<td data-local-id=3D"4172756d-319e-4e5e-9953-9817f9b1228d" class=3D"conflue=
nceTd">
<p local-id=3D"b1ac4452-19ec-4780-90ff-764b4740f50f">string</p></td>
<td data-local-id=3D"bde54858-63f1-424b-ba52-626cfefa9546" class=3D"conflue=
nceTd">
<p local-id=3D"3f24addd-5a80-4277-acb8-2855a157f362">ID of cohort to check =
status of.</p></td>
</tr>
<tr data-local-id=3D"103b5862-e9ca-4586-bd2e-99d550280d71">
<td colspan=3D"3" data-local-id=3D"8cd6a113-e1b9-4efe-b354-898622d3be7a" cl=
ass=3D"confluenceTd">
<p local-id=3D"64f37c35-2fb3-4eb2-afde-06231e8fd5db"><strong>Returns</stron=
g></p></td>
</tr>
<tr data-local-id=3D"b080acb9-95a9-4c64-bda6-db1ed7f9817a">
<td colspan=3D"3" data-local-id=3D"bc15caee-e1a2-4df1-83a4-0ba87aa0c737" cl=
ass=3D"confluenceTd">
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
<div class=3D"codeContent panelContent pdl">
<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: java; gutter: false; theme: Confluence" data-theme=3D"Confluence">{
  'result': 'success',
  'message': 'Email not associated with cohort' | 'Email associated with co=
hort but no device connected' | 'Email associated with cohort and has devic=
e connected'
  'status': 0 | 1 | 2
}
// status 0 if email not associated with cohort, status 1 if email is assoc=
iated with cohort but no device, status 3 if email is associated and has co=
nnected device.</pre>
</div>
</div></td>
</tr>
</tbody>
</table>
</div>
<div class=3D"table-wrap">
<table data-table-width=3D"1011" data-layout=3D"default" data-local-id=3D"a=
ad94252-0a88-413a-a9c1-0a9f4b4adc13" class=3D"confluenceTable">
<colgroup>
<col style=3D"width: 219.0px;">
<col style=3D"width: 792.0px;">
</colgroup>
<tbody>
<tr data-local-id=3D"0bd2c723-30e1-415e-9ab8-24a5a9192c48">
<td data-local-id=3D"7226c851-40c9-4612-b532-bfbaaa769b6c" class=3D"conflue=
nceTd">
<div class=3D"panel" style=3D"background-color: #E6FCFF;border-width: 1px;"=
>
<div class=3D"panelContent" style=3D"background-color: #E6FCFF;">
<p local-id=3D"14bec881-c389-46f6-865d-5ed7551a03f9"><strong>GET</strong></=
p>
</div>
</div></td>
<td data-local-id=3D"aff6772b-a88b-4881-8ef3-ea27cfaed0d0" class=3D"conflue=
nceTd">
<div class=3D"panel" style=3D"background-color: #E6FCFF;border-width: 1px;"=
>
<div class=3D"panelContent" style=3D"background-color: #E6FCFF;">
<p local-id=3D"c8e9a4c7-2efd-4e21-810f-423ec026cc07"><strong>/retrieve-sess=
ion-data</strong></p>
</div>
</div></td>
</tr>
<tr data-local-id=3D"6591c3bf-a47b-4827-8072-9b2c8ef15e97">
<td colspan=3D"2" data-local-id=3D"6e660ddf-34bf-4fa0-bdbf-fe203a8dc0e3" cl=
ass=3D"confluenceTd">
<p local-id=3D"dd061a08-68c3-4a08-a974-5fb43603373c"><strong>Headers</stron=
g></p></td>
</tr>
<tr data-local-id=3D"d3bf8e91-70e3-4a29-9666-fe979eb39a8e">
<td data-local-id=3D"3e712a72-ad7a-4479-963b-f86494411c27" class=3D"conflue=
nceTd">
<p local-id=3D"ee672a72-b316-48d6-9578-619e5e799129">Authorization</p></td>
<td data-local-id=3D"152d6937-172a-4b18-9cfa-b42ab003c311" class=3D"conflue=
nceTd">
<p local-id=3D"154988d6-fb08-4d27-9751-da1d29fdede7">string</p>
<hr local-id=3D"d7b6ea0a-bd01-4022-b811-d8cb79094d1b">
<p local-id=3D"7f2cbda5-3f36-46e7-bb26-b6984bb3df4e">Uses Bearer authentica=
tion. Example:</p>
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
<div class=3D"codeContent panelContent pdl">
<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: java; gutter: false; theme: Confluence" data-theme=3D"Confluence">Bearer =
&lt;sessionId&gt;</pre>
</div>
</div></td>
</tr>
<tr data-local-id=3D"84c4efc8-4696-4fb6-a5ae-1c02e058ca64">
<td colspan=3D"2" data-local-id=3D"fc21aa0e-7eca-412e-b59a-233b9526b170" cl=
ass=3D"confluenceTd">
<p local-id=3D"634f5a0b-b3c7-4e3b-a504-ce5a93474217"><strong>Returns</stron=
g></p></td>
</tr>
<tr data-local-id=3D"8e756244-07db-4556-af8f-3fb8a0cae24c">
<td colspan=3D"2" data-local-id=3D"1a3c42b7-e884-4982-ba7d-e3180375cae5" cl=
ass=3D"confluenceTd">
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
<div class=3D"codeContent panelContent pdl">
<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: java; gutter: false; theme: Confluence" data-theme=3D"Confluence">{
   'session_id': sessionId (string),
   'user': (User Object if existing user, else undefined),
   'email': emailUsedToStartSession (string),
   'cohort': (Cohort Object),
   'tenant': (Tenant Object),
   'cohort_member': (If cohort member exists, is equal to the cohort member=
 permission level, int between 1-3, else undefined),
   'cohort_member_obj': (Cohort member if exists),
   'vendor_config': (Dictionary containing vendors and their linked status =
ex: {"apple":false, "coros":false, "fitbit":false, "garmin":true, "polar":f=
alse, "suunto":true})
